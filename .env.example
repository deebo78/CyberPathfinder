# Database Configuration
DATABASE_URL=postgresql://username:password@hostname:port/database

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# ======================
# SECURITY CONFIGURATION
# ======================

# Admin API Key Authentication (REQUIRED for admin endpoints in production)
# Generate a secure key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key must be provided in the X-Admin-API-Key header for admin endpoints
ADMIN_API_KEY=generate_a_secure_64_character_hex_key_here

# Admin UI Visibility (controls frontend UI elements only - NOT security)
# Set to 'true' to show admin tools in the UI
# WARNING: This does NOT authenticate - always set ADMIN_API_KEY above
VITE_ENABLE_ADMIN=false

# Environment Mode
# Set to 'production' in production to enable security hardening
NODE_ENV=development

# PostgreSQL Configuration (if using local database)
PGDATABASE=cyberpathfinder
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password